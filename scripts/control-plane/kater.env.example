# ChefGroep company-control Kater shadow (non-secret)
# Secrets belong in /etc/chef/kater/secrets.env (mode 0600, root-owned).

KATER_PUBLIC=0
KATER_AUTH_MODE=none
KATER_PROXY=0
KATER_HOST=127.0.0.1
KATER_PROFILE=ops,cloud,research,code,web
KATER_API_PORT=9091
KATER_MCP_PORT=9090
KATER_WS_PORT=9092
KATER_RATE_LIMIT=120

# Company-control repo pin for PR tools (no UDO paths)
KATER_PR_REPO=OnlineChefGroep/kater-dev-tools
