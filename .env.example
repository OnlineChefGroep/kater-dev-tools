# Copy to .env for local Docker Compose. Do not commit real secrets.

# ── Gateway ──────────────────────────────────────────────────────
KATER_PROFILE=core

# Local dev (loopback, no auth):
# KATER_HOST=127.0.0.1

# Public / tunnel exposure — REQUIRED before going live:
# KATER_PUBLIC=1
# KATER_AUTH_MODE=oauth          # ChatGPT Remote MCP (recommended)
# KATER_AUTH_MODE=apikey         # Cursor / agents with Bearer token
# KATER_API_KEY=                 # required when auth=apikey
# KATER_RATE_LIMIT=60
# KATER_CORS_ORIGINS=https://your-domain.example

# ── Optional MCP adapter keys ────────────────────────────────────
# GITHUB_PERSONAL_ACCESS_TOKEN=
# GITLAB_PERSONAL_ACCESS_TOKEN=
# LINEAR_API_KEY=
# EXA_API_KEY=
# FIRECRAWL_API_KEY=
# HF_TOKEN=
# BRAVE_API_KEY=
# SANITY_API_TOKEN=
# SENTRY_AUTH_TOKEN=
# NOTION_API_KEY=
# UPSTASH_EMAIL=
# UPSTASH_API_KEY=
# RESEND_API_KEY=
# SLACK_BOT_TOKEN=
# DATABASE_URL=

# ── Optional custom adapters ─────────────────────────────────────
# UTRECHT_MCP_URL=http://127.0.0.1:9090/sse
# UTRECHT_REPO_PATH=/path/to/your/project
