# Copy to .env for local Docker Compose. Do not commit real secrets.

# ── Gateway ──────────────────────────────────────────────────────
KATER_PROFILE=core

# Local dev (loopback, no auth):
# KATER_HOST=127.0.0.1

# Public / tunnel exposure — REQUIRED before going live:
# KATER_PUBLIC=1
# KATER_AUTH_MODE=oauth          # ChatGPT Remote MCP (recommended)
# KATER_AUTH_MODE=apikey         # Cursor / agents with Bearer token
# KATER_API_KEY=                 # required when auth=apikey
# KATER_RATE_LIMIT=60
# KATER_CORS_ORIGINS=https://your-domain.example

# ── Ports (optional, defaults: API=9091, MCP=9090, WS=9092) ─────
# KATER_API_PORT=9091
# KATER_MCP_PORT=9090
# KATER_WS_PORT=9092

# ── OAuth (when KATER_AUTH_MODE=oauth) ───────────────────────────
# KATER_OAUTH_ISSUER=
# KATER_OAUTH_AUDIENCE=
# KATER_OAUTH_JWKS_URL=

# ── Hardening (optional, recommended for public deploys) ──────────
# Separate "use tools" from "change settings". When set, sensitive settings
# mutations (auth mode, api_keys, CORS, rate limit) require this admin key.
# KATER_ADMIN_KEY=
# Lock down OAuth dynamic client registration (/register). When set, callers
# must pass X-Registration-Token (or ?registration_token=) to register a client.
# KATER_REGISTRATION_TOKEN=
# Dashboard shortcut key — bypasses OAuth token validation in oauth mode for a
# browser-side dashboard session. Optional; unset = disabled.
# KATER_DASHBOARD_KEY=

# ── Proxy (optional) ─────────────────────────────────────────────
# Enable the MCP proxy engine (tool aggregation across multiple servers).
# KATER_PROXY=1
# Enable live MCP proxy backends in `kater serve` (requires adapter API keys).
# Comma-separated public-facing hostnames for HTTPS detection behind tunnels.
# KATER_HTTPS_HOSTS=your-domain.example
# Self-referencing MCP SSE URL (used by external adapter to discover itself).
# KATER_URL=http://127.0.0.1:9090

# ── Tunnel (optional) ────────────────────────────────────────────
# KATER_DOMAIN=your-domain.example
# KATER_TUNNEL_UNIT=kater-tunnel  # systemd unit name override

# ── Optional MCP adapter keys ────────────────────────────────────
# GITHUB_PERSONAL_ACCESS_TOKEN=
# GITLAB_PERSONAL_ACCESS_TOKEN=
# LINEAR_API_KEY=
# Linear MCP bearer token for https://mcp.linear.app/mcp (Settings → Security & Access).
# EXA_API_KEY=
# FIRECRAWL_API_KEY=
# HF_TOKEN=
# BRAVE_API_KEY=
# SANITY_API_TOKEN=
# SENTRY_AUTH_TOKEN=
# NOTION_API_KEY=
# UPSTASH_EMAIL=
# UPSTASH_API_KEY=
# RESEND_API_KEY=
# SLACK_BOT_TOKEN=
# DATABASE_URL=

# ── Optional custom extensions (private deployments) ─────────────
# KATER_EXTENSIONS_MODULE=your_package.extensions
